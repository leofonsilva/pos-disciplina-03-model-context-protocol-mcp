{
  "name": "multiple-mcp-tools",
  "version": "1.0.0",
  "description": "LangGraph agent that wraps SerpAPI Google Trends as a LangChain tool to answer video content strategy questions",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "node --env-file .env src/index.ts",
    "dev": "node --watch --inspect --env-file .env src/index.ts",
    "langgraph:serve": "npx @langchain/langgraph-cli dev",
    "docker:infra:up": "docker compose up -d --wait",
    "docker:infra:down": "docker compose down",
    "docker:infra:cleanup": "docker compose down --volumes --remove-orphans && rm -rf storage",
    "docker:infra:logs": "docker compose logs -f"
  },
  "keywords": [
    "langchain",
    "prompt-chaining",
    "openrouter"
  ],
  "dependencies": {
    "@langchain/core": "^1.1.39",
    "@langchain/langgraph": "^1.2.8",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.4.3",
    "csvtojson": "^2.0.14",
    "fastify": "^5.8.4",
    "langchain": "^1.3.1"
  },
  "devDependencies": {
    "@langchain/langgraph-cli": "^1.1.17",
    "@types/node": "^25.5.2"
  },
  "engines": {
    "node": ">=24.10.0"
  }
}
